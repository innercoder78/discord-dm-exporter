{
  "manifest_version": 3,
  "name": "Discord DM Log Exporter",
  "description": "Local-only exporter for one-on-one Discord Web DMs into clean TXT transcripts.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Discord DM Log Exporter",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "downloads", "scripting", "storage", "tabs"],
  "host_permissions": ["https://discord.com/*"]
}
